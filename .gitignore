# Secrets
ansible/secrets/*
!ansible/secrets/.keep

# hostvars Yaml (Host specific Domains/Portainer etc.)
ansible/hostvars/*.yml
ansible/hostvars/*.yml.bak*
ansible/hostvars/*.yaml.bak*
ansible/hostvars/*~

# redirects
ansible/redirects/*.yml

# Vault
*.vault
*.enc

# Temporary
*.retry
*.log
*.tmp
*.bak

# Docker volumes (falls lokal)
data/
volumes/

# Runtime data (DO NOT COMMIT)
data/*
!data/.keep

# backup-folder and huge backup-files
backups/
*.zip
*.tar.gz

secrets/
secrets/*.yml
!secrets/README.md

# Sheet Helper local build/cache data
apps/sheet-helper/.gocache/
apps/sheet-helper/.gomodcache/
apps/sheet-helper/*.db
apps/static-inline-editor/.gocache/
apps/static-inline-editor/.gomodcache/

# Go specific temp files
.gocache/
.gomodcache/
