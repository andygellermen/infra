{
  "name": "easy-author-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "check:node": "node -e \"var major=+process.versions.node.split('.')[0]; if(major<20||major>=21){console.error('easy-author frontend requires Node 20.x. Current: '+process.version+'\\nRun: nvm use (inside apps/easy-author/frontend)'); process.exit(1)}\"",
    "dev": "npm run check:node && vite",
    "build": "npm run check:node && vite build",
    "preview": "npm run check:node && vite preview",
    "test:markdown": "npm run check:node && node --test src/lib/markdown.test.js",
    "test:editor": "npm run check:node && vitest run src/App.test.jsx src/components/EditorPane.test.jsx",
    "test": "npm run test:markdown && npm run test:editor"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "vite": "^5.4.10",
    "vitest": "^4.1.8"
  }
}
