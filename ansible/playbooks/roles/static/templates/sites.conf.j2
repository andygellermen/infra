{% for site in static_sites_rendered | sort(attribute='domain') %}
{% set root_auth_candidates = (
  site.static_basic_auth_paths
  | default([], true)
  | selectattr('path', 'defined')
  | selectattr('path', 'equalto', '/')
  | selectattr('auth_file', 'defined')
  | list
) %}
{% set root_auth = root_auth_candidates[0] if (root_auth_candidates | length > 0) else {} %}
server {
    listen 80;
    server_name {{ ([site.domain] + ((site.traefik.aliases | default([], true)) | difference([site.domain]) | unique)) | join(' ') }};

    root /usr/share/nginx/html/{{ site.domain }};
    index index.html index.htm;
    autoindex off;

{% for auth in site.static_basic_auth_paths | default([], true) if (auth.path | default('', true) | length > 0) and (auth.path | default('', true) != '/') and (((auth.username | default('', true) | length > 0) and (auth.password_hash | default('', true) | length > 0)) or (auth.auth_file | default('', true) | length > 0)) %}
{% set auth_path = auth.path | default('/private-folder/') %}
{% set auth_path_slashless = auth_path | regex_replace('/$', '') %}
    location = {{ auth_path_slashless }} {
        return 301 {{ auth_path }};
    }

    location ^~ {{ auth_path }} {
        auth_basic "{{ auth.realm | default('Protected Area') }}";
        auth_basic_user_file /etc/nginx/static-auth/{{ (auth.auth_file | default('/srv/static-auth/' ~ site.domain ~ '-' ~ (((auth.path | default('/private-folder/')) | regex_replace('^/', '') | regex_replace('/$', '') | regex_replace('[^A-Za-z0-9._-]+', '-')) or 'private') ~ '.htpasswd', true)) | basename }};
        try_files $uri $uri/ =404;
    }

{% endfor %}
    location / {
{% if root_auth %}
        auth_basic "{{ root_auth.realm | default('Protected Area') }}";
        auth_basic_user_file /etc/nginx/static-auth/{{ (root_auth.auth_file | default('/srv/static-auth/' ~ site.domain ~ '-private.htpasswd', true)) | basename }};
{% endif %}
        try_files $uri $uri/ =404;
    }
}

{% endfor %}
