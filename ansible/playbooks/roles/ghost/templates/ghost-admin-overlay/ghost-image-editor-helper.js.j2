(function () {
  "use strict";

  const INSTALL_URL = {{ ghost_image_editor_notice_install_url_effective | to_json }};
  const REMIND_HOURS = {{ ghost_image_editor_notice_remind_hours_effective | int }};
  const EXTRA_TITLE = {{ ghost_image_editor_notice_extra_title_effective | to_json }};
  const EXTRA_TEXT = {{ ghost_image_editor_notice_extra_text_effective | to_json }};
  const NOTICE_ID = "ghost-image-editor-notice";
  const NOTICE_STYLE_ID = "ghost-image-editor-notice-style";
  const PROBE_ID = "ghost-image-editor-extension-probe";
  const STORAGE_KEY = `ghost-image-editor-notice:${window.location.host}:dismissed-until`;
  const EXTENSION_BUTTON_SELECTOR = "[data-ghost-image-editor-inline-action='edit']";

  let extensionDetected = false;
  let scheduledTimer = null;
  let currentUserCache = {
    expiresAt: 0,
    value: undefined
  };

  function isGermanLocale() {
    const language = (document.documentElement.lang || navigator.language || "en").toLowerCase();
    return language.startsWith("de");
  }

  function getText(key) {
    const locale = isGermanLocale() ? "de" : "en";
    const copy = {
      title: {
        de: "Ghost Image Editor installieren",
        en: "Install Ghost Image Editor"
      },
      description: {
        de: "Du bist in Ghost eingeloggt, aber das Browser-Plugin scheint in diesem Browser noch nicht aktiv zu sein.",
        en: "You are signed in to Ghost, but the browser plugin does not seem to be active in this browser yet."
      },
      benefitsTitle: {
        de: "Damit koennen Autoren Bilder direkt im Backend bearbeiten:",
        en: "This helps authors edit images directly inside the Ghost backend:"
      },
      benefitOne: {
        de: "Bildkarten schneller oeffnen und anpassen",
        en: "Open and adjust image cards faster"
      },
      benefitTwo: {
        de: "Feature Images direkt beim Upload bearbeiten",
        en: "Edit feature images directly during upload"
      },
      benefitThree: {
        de: "Weniger Wechsel zwischen Ghost und externen Tools",
        en: "Reduce switching between Ghost and external tools"
      },
      note: {
        de: "Dieser Hinweis erscheint nur fuer eingeloggte Ghost-Nutzer im Backend.",
        en: "This notice is only shown to signed-in Ghost users inside the backend."
      },
      install: {
        de: "Plugin auf GitHub oeffnen",
        en: "Open plugin on GitHub"
      },
      remind: {
        de: "Spaeter erinnern",
        en: "Remind me later"
      },
      recheck: {
        de: "Erneut pruefen",
        en: "Check again"
      },
      dismiss: {
        de: "Heute ausblenden",
        en: "Hide for today"
      },
      installedHint: {
        de: "Schon installiert? Klicke auf 'Erneut pruefen' oder lade Ghost neu.",
        en: "Already installed? Click 'Check again' or reload Ghost."
      }
    };

    return copy[key] && (copy[key][locale] || copy[key].en) || key;
  }

  function isAuthRoute() {
    const locationText = `${window.location.pathname}${window.location.hash}`.toLowerCase();
    return locationText.includes("/signin") || locationText.includes("/setup") || locationText.includes("/unlock");
  }

  function getGhostAdminBaseUrl() {
    const pathname = window.location.pathname || "/ghost/";
    const ghostIndex = pathname.indexOf("/ghost");

    if (ghostIndex === -1) {
      return `${window.location.origin}/ghost/`;
    }

    const prefix = pathname.slice(0, ghostIndex);
    return `${window.location.origin}${prefix}/ghost/`;
  }

  function getDismissedUntil() {
    try {
      return Number(window.localStorage.getItem(STORAGE_KEY) || "0");
    } catch (_error) {
      return 0;
    }
  }

  function setDismissedForHours(hours) {
    try {
      const until = Date.now() + (hours * 60 * 60 * 1000);
      window.localStorage.setItem(STORAGE_KEY, String(until));
    } catch (_error) {
      // ignore storage failures
    }
  }

  function clearDismissedUntil() {
    try {
      window.localStorage.removeItem(STORAGE_KEY);
    } catch (_error) {
      // ignore storage failures
    }
  }

  function ensureProbeInput() {
    if (!document.body) return null;

    let probe = document.getElementById(PROBE_ID);
    if (probe) return probe;

    probe = document.createElement("input");
    probe.type = "file";
    probe.id = PROBE_ID;
    probe.tabIndex = -1;
    probe.setAttribute("aria-hidden", "true");
    probe.dataset.ghostImageEditorProbe = "true";
    probe.style.position = "fixed";
    probe.style.opacity = "0";
    probe.style.pointerEvents = "none";
    probe.style.width = "1px";
    probe.style.height = "1px";
    probe.style.left = "-9999px";
    probe.style.top = "-9999px";
    document.body.appendChild(probe);

    return probe;
  }

  function isExtensionDetected() {
    if (document.querySelector(EXTENSION_BUTTON_SELECTOR)) {
      extensionDetected = true;
      return true;
    }

    const probe = document.getElementById(PROBE_ID);
    if (probe && probe.dataset.editorAttached === "true") {
      extensionDetected = true;
      return true;
    }

    return extensionDetected;
  }

  function waitForExtensionDetection(timeoutMs) {
    ensureProbeInput();

    if (isExtensionDetected()) {
      return Promise.resolve(true);
    }

    const startedAt = Date.now();

    return new Promise((resolve) => {
      function tick() {
        if (isExtensionDetected()) {
          resolve(true);
          return;
        }

        if ((Date.now() - startedAt) >= timeoutMs) {
          resolve(false);
          return;
        }

        window.setTimeout(tick, 120);
      }

      tick();
    });
  }

  function fetchCurrentUser() {
    const now = Date.now();
    if (now < currentUserCache.expiresAt) {
      return Promise.resolve(currentUserCache.value);
    }

    return window.fetch(
        new URL("api/admin/users/me/?include=roles", getGhostAdminBaseUrl()).toString(),
        {
          credentials: "include",
          headers: {
            Accept: "application/json"
          }
        }
      )
      .then((response) => {
        if (!response.ok) {
          currentUserCache = {
            expiresAt: now + 5000,
            value: null
          };
          return null;
        }

        return response.json().then((payload) => {
          const user = payload && payload.users && payload.users[0] ? payload.users[0] : null;
          currentUserCache = {
            expiresAt: now + 15000,
            value: user
          };

          return user;
        });
      })
      .catch(() => {
        currentUserCache = {
          expiresAt: now + 5000,
          value: null
        };
        return null;
      });
  }

  function ensureNoticeStyles() {
    if (document.getElementById(NOTICE_STYLE_ID)) return;

    const style = document.createElement("style");
    style.id = NOTICE_STYLE_ID;
    style.textContent = `
      #${NOTICE_ID} {
        position: fixed;
        inset: 0;
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(9, 10, 15, 0.52);
        backdrop-filter: blur(6px);
      }

      #${NOTICE_ID}[hidden] {
        display: none;
      }

      #${NOTICE_ID} .gie-modal {
        width: min(100%, 560px);
        border-radius: 22px;
        background: linear-gradient(180deg, #ffffff 0%, #f4f6fb 100%);
        color: #101828;
        box-shadow: 0 28px 90px rgba(15, 23, 42, 0.28);
        border: 1px solid rgba(148, 163, 184, 0.24);
        overflow: hidden;
      }

      #${NOTICE_ID} .gie-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        padding: 26px 28px 12px;
      }

      #${NOTICE_ID} .gie-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: #14532d;
        background: #dcfce7;
      }

      #${NOTICE_ID} .gie-title {
        margin: 14px 0 8px;
        font-size: 28px;
        line-height: 1.1;
        font-weight: 800;
      }

      #${NOTICE_ID} .gie-description,
      #${NOTICE_ID} .gie-note,
      #${NOTICE_ID} .gie-installed-hint {
        margin: 0;
        font-size: 15px;
        line-height: 1.6;
        color: #475467;
      }

      #${NOTICE_ID} .gie-body {
        padding: 0 28px 18px;
      }

      #${NOTICE_ID} .gie-benefits-title {
        margin: 12px 0 12px;
        font-size: 14px;
        font-weight: 700;
        color: #1f2937;
      }

      #${NOTICE_ID} .gie-benefits {
        margin: 0 0 18px;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 10px;
      }

      #${NOTICE_ID} .gie-benefits li {
        padding: 12px 14px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(148, 163, 184, 0.18);
        font-size: 14px;
        line-height: 1.45;
        color: #1f2937;
      }

      #${NOTICE_ID} .gie-extra {
        margin-top: 18px;
        padding: 14px 16px;
        border-radius: 14px;
        background: rgba(17, 24, 39, 0.04);
        border: 1px solid rgba(148, 163, 184, 0.18);
      }

      #${NOTICE_ID} .gie-extra-title {
        margin: 0 0 6px;
        font-size: 14px;
        font-weight: 700;
        color: #1f2937;
      }

      #${NOTICE_ID} .gie-extra-text {
        margin: 0;
        font-size: 14px;
        line-height: 1.6;
        color: #475467;
        white-space: pre-line;
      }

      #${NOTICE_ID} .gie-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
      }

      #${NOTICE_ID} .gie-button {
        appearance: none;
        border: 0;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: transform 140ms ease, box-shadow 140ms ease, background 140ms ease;
      }

      #${NOTICE_ID} .gie-button:hover {
        transform: translateY(-1px);
      }

      #${NOTICE_ID} .gie-button-primary {
        color: #ffffff;
        background: linear-gradient(135deg, #111827 0%, #1d4ed8 100%);
        box-shadow: 0 14px 30px rgba(29, 78, 216, 0.28);
      }

      #${NOTICE_ID} .gie-button-secondary {
        color: #1f2937;
        background: #e5e7eb;
      }

      #${NOTICE_ID} .gie-button-ghost {
        color: #475467;
        background: transparent;
      }

      #${NOTICE_ID} .gie-close {
        appearance: none;
        border: 0;
        background: transparent;
        color: #667085;
        cursor: pointer;
        font-size: 22px;
        line-height: 1;
        padding: 4px;
      }

      #${NOTICE_ID} .gie-footer {
        display: grid;
        gap: 8px;
        padding: 14px 28px 24px;
        background: rgba(255, 255, 255, 0.55);
        border-top: 1px solid rgba(148, 163, 184, 0.16);
      }

      @media (max-width: 640px) {
        #${NOTICE_ID} {
          padding: 14px;
        }

        #${NOTICE_ID} .gie-header,
        #${NOTICE_ID} .gie-body,
        #${NOTICE_ID} .gie-footer {
          padding-left: 18px;
          padding-right: 18px;
        }

        #${NOTICE_ID} .gie-title {
          font-size: 24px;
        }

        #${NOTICE_ID} .gie-actions {
          flex-direction: column;
        }

        #${NOTICE_ID} .gie-button {
          width: 100%;
        }
      }
    `;

    document.head.appendChild(style);
  }

  function closeNotice() {
    const modal = document.getElementById(NOTICE_ID);
    if (modal) {
      modal.remove();
    }
  }

  function showNotice() {
    if (!document.body) return;

    if (document.getElementById(NOTICE_ID)) {
      return;
    }

    ensureNoticeStyles();

    const modal = document.createElement("div");
    modal.id = NOTICE_ID;
    modal.setAttribute("role", "dialog");
    modal.setAttribute("aria-modal", "true");
    modal.innerHTML = `
      <div class="gie-modal">
        <div class="gie-header">
          <div>
            <div class="gie-badge">Ghost Backend Helper</div>
            <h2 class="gie-title">${getText("title")}</h2>
            <p class="gie-description">${getText("description")}</p>
          </div>
          <button type="button" class="gie-close" aria-label="Close">&times;</button>
        </div>
        <div class="gie-body">
          <p class="gie-benefits-title">${getText("benefitsTitle")}</p>
          <ul class="gie-benefits">
            <li>${getText("benefitOne")}</li>
            <li>${getText("benefitTwo")}</li>
            <li>${getText("benefitThree")}</li>
          </ul>
          <div class="gie-actions">
            <button type="button" class="gie-button gie-button-primary" data-action="install">${getText("install")}</button>
            <button type="button" class="gie-button gie-button-secondary" data-action="recheck">${getText("recheck")}</button>
            <button type="button" class="gie-button gie-button-ghost" data-action="remind">${getText("remind")}</button>
          </div>
        </div>
        <div class="gie-footer">
          <p class="gie-note">${getText("note")}</p>
          <p class="gie-installed-hint">${getText("installedHint")}</p>
          <button type="button" class="gie-button gie-button-ghost" data-action="dismiss">${getText("dismiss")}</button>
        </div>
      </div>
    `;

    modal.addEventListener("click", (event) => {
      if (event.target === modal) {
        setDismissedForHours(12);
        closeNotice();
      }
    });

    modal.querySelector("[data-action='install']").addEventListener("click", () => {
      setDismissedForHours(REMIND_HOURS);
      window.open(INSTALL_URL, "_blank", "noopener,noreferrer");
      closeNotice();
    });

    modal.querySelector("[data-action='recheck']").addEventListener("click", () => {
      clearDismissedUntil();
      waitForExtensionDetection(2600).then((installed) => {
        if (installed) {
          closeNotice();
          return;
        }

        scheduleEvaluation(1500);
      });
    });

    modal.querySelector("[data-action='remind']").addEventListener("click", () => {
      setDismissedForHours(REMIND_HOURS);
      closeNotice();
    });

    modal.querySelector("[data-action='dismiss']").addEventListener("click", () => {
      setDismissedForHours(12);
      closeNotice();
    });

    modal.querySelector(".gie-close").addEventListener("click", () => {
      setDismissedForHours(12);
      closeNotice();
    });

    document.addEventListener("keydown", function onKeyDown(event) {
      if (event.key !== "Escape") return;
      document.removeEventListener("keydown", onKeyDown);
      setDismissedForHours(12);
      closeNotice();
    }, { once: true });

    document.body.appendChild(modal);

    if (EXTRA_TITLE || EXTRA_TEXT) {
      const body = modal.querySelector(".gie-body");
      const extra = document.createElement("section");
      extra.className = "gie-extra";

      if (EXTRA_TITLE) {
        const extraTitle = document.createElement("h3");
        extraTitle.className = "gie-extra-title";
        extraTitle.textContent = EXTRA_TITLE;
        extra.appendChild(extraTitle);
      }

      if (EXTRA_TEXT) {
        const extraText = document.createElement("p");
        extraText.className = "gie-extra-text";
        extraText.textContent = EXTRA_TEXT;
        extra.appendChild(extraText);
      }

      body.insertBefore(extra, body.querySelector(".gie-actions"));
    }

    const primaryButton = modal.querySelector("[data-action='install']");
    if (primaryButton) {
      primaryButton.focus();
    }
  }

  function evaluateNotice() {
    if (!document.body) return;

    ensureProbeInput();

    if (isAuthRoute()) {
      closeNotice();
      return;
    }

    fetchCurrentUser().then((user) => {
      if (!user) {
        closeNotice();
        return;
      }

      waitForExtensionDetection(2200).then((installed) => {
        if (installed) {
          clearDismissedUntil();
          closeNotice();
          return;
        }

        if (Date.now() < getDismissedUntil()) {
          closeNotice();
          return;
        }

        showNotice();
      });
    });
  }

  function scheduleEvaluation(delayMs) {
    if (scheduledTimer) {
      window.clearTimeout(scheduledTimer);
    }

    scheduledTimer = window.setTimeout(() => {
      scheduledTimer = null;
      evaluateNotice();
    }, delayMs);
  }

  function installNavigationHooks() {
    const methods = ["pushState", "replaceState"];

    methods.forEach((methodName) => {
      const original = window.history[methodName];
      if (typeof original !== "function") return;

      window.history[methodName] = function patchedHistoryMethod() {
        const result = original.apply(this, arguments);
        scheduleEvaluation(350);
        return result;
      };
    });

    window.addEventListener("hashchange", () => scheduleEvaluation(350));
    window.addEventListener("popstate", () => scheduleEvaluation(350));
    window.addEventListener("focus", () => scheduleEvaluation(0));
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) {
        scheduleEvaluation(0);
      }
    });
  }

  installNavigationHooks();
  [0, 900, 3000, 7000].forEach((delayMs) => {
    window.setTimeout(() => scheduleEvaluation(0), delayMs);
  });
}());
