[Unit]
Description=Immediate enriched CrowdSec incident analysis
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
WorkingDirectory=/home/andy/infra
ExecStartPre=/usr/bin/mkdir -p /home/andy/infra/logs/reports
ExecStartPre=/usr/bin/mkdir -p /home/andy/infra/data/crowdsec/state
ExecStart=/usr/bin/env bash ./scripts/crowdsec-event-report.sh
